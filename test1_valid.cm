int gcd(int u, int v) {
    if (v == 0) return u;
    else return gcd(v, u - (u / v) * v);
}

void main(void) {
    int x;
    int y;
    x = 12;
    y = 144;
    /* compute greatest common divisor */
    if (x <= y) {
        x = gcd(x, y);
    } else {
        x = gcd(y, x);
    }
    while (x >= 0) {
        x = x - 1;
    }
}

